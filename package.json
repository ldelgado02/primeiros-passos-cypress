  },

  "devDependencies": {
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "cypress": "^14.3.2",
    "npm-run-all": "^4.1.5"
  },

  "dependencies": {
    "chance": "^1.1.13"
  }

}

